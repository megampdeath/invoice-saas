# Copy to .env and fill in. Only NEXT_PUBLIC_* values are browser-safe.
APP_ENV=development
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/postgres
DIRECT_DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/postgres

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_ISSUER=https://YOUR-PROJECT.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

STORAGE_BACKEND=supabase
SUPABASE_STORAGE_ORIGINALS_BUCKET=invoice-originals
SUPABASE_STORAGE_EXPORTS_BUCKET=invoice-exports
SUPABASE_STORAGE_OCR_RAW_BUCKET=ocr-raw-results

EXTRACTION_PROVIDER=mock   # mock | pdf_text | textract

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PREVIEW_TOKEN_SECRET=changeme

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
